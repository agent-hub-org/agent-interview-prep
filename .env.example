# --- Local development defaults (override for Railway) ---
PORT=9003
GROQ_API_KEY=
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=agent_interview_prep
MEM0_API_KEY=

# MCP tool server — use Railway internal URL in production
# Railway: http://mcp-tool-servers.railway.internal/mcp
MCP_SERVER_URL=http://localhost:8010/mcp

# Research agent — use Railway internal URL in production
# Railway: http://agent-research.railway.internal:8081
RESEARCH_AGENT_URL=http://localhost:9002

# Public URL of this agent (for A2A agent card)
AGENT_PUBLIC_URL=http://localhost:9003

# Note: File uploads and generated notes are stored in MongoDB GridFS
# (no local filesystem dependency — safe for Railway's ephemeral FS)
