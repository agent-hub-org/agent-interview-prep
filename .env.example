# LLM
AZURE_AI_FOUNDRY_ENDPOINT=https://<resource>.services.ai.azure.com/openai/v1
AZURE_AI_FOUNDRY_API_KEY=

# Optional alternative LLM providers (leave blank if not using)
GROQ_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=

# Memory & storage
MEM0_API_KEY=
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
MONGO_DB_NAME=agent_interview_prep

# MCP server
MCP_SERVER_URL=http://mcp-tool-servers:8010/mcp

# Research agent (internal Docker service)
RESEARCH_AGENT_URL=http://agent-research:8081

# A2A agent card — set to the URL marketplace uses to reach this agent
AGENT_PUBLIC_URL=http://agent-interview-prep:9003

# Base URL used to generate file download links in notes
# Set to the marketplace proxy path so links are externally accessible
BACKEND_URL=http://<OCI_PUBLIC_IP>:9000/agents/agent-interview-prep

# Server
PORT=9003
